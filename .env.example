# ──────────────────────────────────────────────────────────────────
# Weather & Sunrise/Sunset Agent — Environment Variables
# Copy this file to .env and fill in your values.
# ──────────────────────────────────────────────────────────────────

# ── Your custom LLM endpoint ──────────────────────────────────────
# Base URL of your OpenAI-compatible chat server.
# Examples:
#   Ollama:    http://localhost:11434/v1
#   vLLM:      http://localhost:8000/v1
#   LM Studio: http://localhost:1234/v1
CUSTOM_LLM_BASE_URL=http://localhost:11434/v1

# Model name to request from the server
CUSTOM_LLM_MODEL=llama3.2

# API key (use any string for servers that don't require auth)
CUSTOM_LLM_API_KEY=custom

# ── ADK settings ─────────────────────────────────────────────────
# Required by ADK when NOT using Google/Vertex AI
GOOGLE_GENAI_USE_VERTEXAI=false
