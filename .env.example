# ──────────────────────────────────────────────────────────
# Weather & Sunrise/Sunset Agent — Environment Variables
# Copy this file to .env and fill in your values.
# ──────────────────────────────────────────────────────────

# Ollama model name (must be pulled locally via `ollama pull <model>`)
# Examples: llama3.2  |  llama3.1  |  gemma3  |  mistral  |  phi4
OLLAMA_MODEL=llama3.2

# Ollama server URL (default is localhost — change if running remotely)
OLLAMA_BASE_URL=http://localhost:11434

# Required by Google ADK (set to any non-empty string when using Ollama)
GOOGLE_GENAI_USE_VERTEXAI=false
