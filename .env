# ─────────────────────────────────────────────────────────────────────────
# Google ADK — Environment configuration
# This file is auto-loaded by `adk web` from the agents directory.
# ─────────────────────────────────────────────────────────────────────────

# Required: tell ADK not to use Google Vertex AI (we use a custom LLM)
GOOGLE_GENAI_USE_VERTEXAI=false

# Required: ADK checks this at startup; set to any non-empty value
# (your actual custom LLM auth is handled separately in agent.py)
GOOGLE_API_KEY=not-needed

# ── Your custom LLM endpoint ──────────────────────────────────────────────
# Base URL for your OpenAI-compatible server:
#   Ollama  → http://localhost:11434/v1
#   vLLM    → http://localhost:8000/v1
#   LMStudio→ http://localhost:1234/v1
CUSTOM_LLM_BASE_URL=http://localhost:11434/v1

# Model name (must be available on your server)
CUSTOM_LLM_MODEL=llama3.2

# API key (any string works for keyless/local servers)
CUSTOM_LLM_API_KEY=custom
